# Dashboard Central - Backend Environment Variables
# Copy this file to .env and customize values

# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# AIOX Framework
AIOX_CORE_DIR=../../../.aiox-core
PROJECT_ROOT=../../..

# Logging
LOG_LEVEL=info
LOG_FILE=../../../.aiox/logs/dashboard.log
LOG_DIR=../../../.aiox/logs

# Health Check
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# WebSocket
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws
WEBSOCKET_RECONNECTION_DELAY=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004,http://localhost:3005

# API Configuration
API_PREFIX=/api
API_VERSION=v1
API_TIMEOUT=30000

# Feature Flags
FEATURE_WORKFLOW_DISPATCHER=true
FEATURE_LOG_VIEWER=true
FEATURE_AGENT_MONITOR=true
FEATURE_GIT_INTEGRATION=false
FEATURE_NOTIFICATIONS=false

# Performance
HEALTH_HISTORY_SIZE=100
LOG_BUFFER_SIZE=500
LOG_RETENTION_DAYS=7
CACHE_TTL=60000
ENABLE_COMPRESSION=true
ENABLE_CACHING=true

# Security
HELMET_ENABLED=true
CONTENT_SECURITY_POLICY=false
AUTHENTICATION_ENABLED=false
