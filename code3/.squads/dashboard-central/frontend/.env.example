# Dashboard Central - Frontend Environment Variables
# Copy this file to .env.local and customize values

# API Configuration
REACT_APP_API_URL=http://localhost:3000
REACT_APP_API_PREFIX=/api
REACT_APP_API_VERSION=v1

# WebSocket Configuration
REACT_APP_WEBSOCKET_URL=ws://localhost:3000
REACT_APP_WEBSOCKET_PATH=/ws

# Feature Flags
REACT_APP_FEATURE_WORKFLOW_DISPATCHER=true
REACT_APP_FEATURE_LOG_VIEWER=true
REACT_APP_FEATURE_AGENT_MONITOR=true
REACT_APP_FEATURE_GIT_INTEGRATION=false

# UI Configuration
REACT_APP_THEME=dark
REACT_APP_THEME_COLOR=#00d4ff
REACT_APP_LOG_LINES=100
REACT_APP_HEALTH_CHECK_INTERVAL=30000

# Development
REACT_APP_DEBUG=false
REACT_APP_LOG_NETWORK=false
