, 0.3);\n            border-radius: 8px;\n            color: #00d4ff;\n            cursor: pointer;\n            font-size: 0.9rem;\n            transition: all 0.3s ease;\n            margin-left: 10px;\n        }\n\n        .name-edit:hover {\n            background: rgba(0, 212, 255, 0.2);\n            border-color: rgba(0, 212, 255, 0.6);\n        }\n\n        .date-display {\n            font-size: 1.1rem;\n            color: #00ff88;\n            margin-top: 10px;\n            font-weight: 500;\n        }\n\n        .dashboard-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));\n            gap: 25px;\n            margin-bottom: 30px;\n        }\n\n        .card {\n            background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(26, 26, 46, 0.4) 100%);\n            border: 1px solid rgba(0, 212, 255, 0.2);\n            border-radius: 12px;\n            padding: 25px;\n            backdrop-filter: blur(10px);\n            transition: all 0.3s ease;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);\n        }\n\n        .card:hover {\n            border-color: rgba(0, 212, 255, 0.5);\n            box-shadow: 0 8px 32px rgba(0, 212, 255, 0.15);\n            transform: translateY(-5px);\n        }\n\n        .card-title {\n            font-size: 1.3rem;\n            font-weight: 600;\n            color: #00d4ff;\n            margin-bottom: 20px;\n            display: flex;\n            align-items: center;\n            gap: 10px;\n        }\n\n        .card-title::before {\n            content: '';\n            width: 3px;\n            height: 20px;\n            background: linear-gradient(135deg, #00d4ff, #0099ff);\n            border-radius: 2px;\n        }\n\n        /* Clock */\n        .clock {\n            font-size: 3.5rem;\n            font-weight: 300;\n            text-align: center;\n            color: #00ff88;\n            font-family: 'Courier New', monospace;\n            letter-spacing: 2px;\n            margin: 30px 0;\n        }\n\n        /* Tasks */\n        .tasks-container {\n            display: flex;\n            flex-direction: column;\n            gap: 12px;\n            max-height: 400px;\n            overflow-y: auto;\n            padding-right: 10px;\n        }\n\n        .tasks-container::-webkit-scrollbar {\n            width: 6px;\n        }\n\n        .tasks-container::-webkit-scrollbar-track {\n            background: rgba(0, 212, 255, 0.05);\n            border-radius: 3px;\n        }\n\n        .tasks-container::-webkit-scrollbar-thumb {\n            background: rgba(0, 212, 255, 0.3);\n            border-radius: 3px;\n        }\n\n        .tasks-container::-webkit-scrollbar-thumb:hover {\n            background: rgba(0, 212, 255, 0.5);\n        }\n\n        .task-item {\n            display: flex;\n            align-items: center;\n            padding: 12px;\n            background: rgba(0, 0, 0, 0.3);\n            border-radius: 8px;\n            border: 1px solid rgba(0, 212, 255, 0.1);\n            transition: all 0.3s ease;\n        }\n\n        .task-item:hover {\n            background: rgba(0, 212, 255, 0.05);\n            border-color: rgba(0, 212, 255, 0.3);\n        }\n\n        .task-item.completed {\n            opacity: 0.6;\n        }\n\n        .task-item.completed .task-text {\n            text-decoration: line-through;\n            color: #888;\n        }\n\n        .task-checkbox {\n            width: 20px;\n            height: 20px;\n            margin-right: 12px;\n            cursor: pointer;\n            accent-color: #00d4ff;\n        }\n\n        .task-text {\n            flex: 1;\n            color: #e0e0e0;\n            word-break: break-word;\n        }\n\n        .task-delete {\n            background: rgba(255, 0, 88, 0.2);\n            border: none;\n            color: #ff0058;\n            width: 28px;\n            height: 28px;\n            border-radius: 6px;\n            cursor: pointer;\n            font-size: 16px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.3s ease;\n            margin-left: 8px;\n        }\n\n        .task-delete:hover {\n            background: rgba(255, 0, 88, 0.4);\n            transform: scale(1.1);\n        }\n\n        .task-input-group {\n            display: flex;\n            gap: 10px;\n            margin-top: 15px;\n        }\n\n        .task-input {\n            flex: 1;\n            padding: 10px 15px;\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(0, 212, 255, 0.2);\n            border-radius: 8px;\n            color: #e0e0e0;\n            font-size: 0.95rem;\n            transition: all 0.3s ease;\n        }\n\n        .task-input:focus {\n            outline: none;\n            border-color: rgba(0, 212, 255, 0.6);\n            background: rgba(0, 212, 255, 0.05);\n        }\n\n        .task-btn {\n            padding: 10px 20px;\n            background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);\n            border: none;\n            border-radius: 8px;\n            color: #0f0f1e;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n\n        .task-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.3);\n        }\n\n        /* Notes */\n        .notes-container {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n            height: 100%;\n        }\n\n        .note-textarea {\n            flex: 1;\n            padding: 15px;\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(0, 212, 255, 0.2);\n            border-radius: 8px;\n            color: #e0e0e0;\n            font-family: 'Courier New', monospace;\n            font-size: 0.95rem;\n            resize: none;\n            transition: all 0.3s ease;\n        }\n\n        .note-textarea:focus {\n            outline: none;\n            border-color: rgba(0, 212, 255, 0.6);\n            background: rgba(0, 212, 255, 0.05);\n        }\n\n        .note-save-btn {\n            padding: 12px;\n            background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);\n            border: none;\n            border-radius: 8px;\n            color: #0f0f1e;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n\n        .note-save-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(0, 255, 136, 0.3);\n        }\n\n        .save-indicator {\n            font-size: 0.85rem;\n            color: #00ff88;\n            text-align: center;\n            min-height: 20px;\n        }\n\n        /* Modal */\n        .modal {\n            display: none;\n            position: fixed;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: rgba(0, 0, 0, 0.7);\n            backdrop-filter: blur(5px);\n            z-index: 1000;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .modal.active {\n            display: flex;\n        }\n\n        .modal-content {\n            background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(26, 26, 46, 0.85) 100%);\n            border: 1px solid rgba(0, 212, 255, 0.3);\n            border-radius: 12px;\n            padding: 30px;\n            max-width: 400px;\n            width: 90%;\n            animation: slideIn 0.3s ease;\n        }\n\n        .modal-title {\n            font-size: 1.5rem;\n            color: #00d4ff;\n            margin-bottom: 20px;\n        }\n\n        .modal-input {\n            width: 100%;\n            padding: 12px 15px;\n            background: rgba(0, 0, 0, 0.3);\n            border: 1px solid rgba(0, 212, 255, 0.2);\n            border-radius: 8px;\n            color: #e0e0e0;\n            font-size: 1rem;\n            margin-bottom: 20px;\n            transition: all 0.3s ease;\n        }\n\n        .modal-input:focus {\n            outline: none;\n            border-color: rgba(0, 212, 255, 0.6);\n            background: rgba(0, 212, 255, 0.05);\n        }\n\n        .modal-buttons {\n            display: flex;\n            gap: 10px;\n            justify-content: flex-end;\n        }\n\n        .modal-btn {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 8px;\n            cursor: pointer;\n            font-weight: 600;\n            transition: all 0.3s ease;\n        }\n\n        .modal-btn-save {\n            background: linear-gradient(135deg, #00d4ff 0%, #0099ff 100%);\n            color: #0f0f1e;\n        }\n\n        .modal-btn-save:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.3);\n        }\n\n        .modal-btn-cancel {\n            background: rgba(255, 255, 255, 0.1);\n            color: #e0e0e0;\n            border: 1px solid rgba(255, 255, 255, 0.2);\n        }\n\n        .modal-btn-cancel:hover {\n            background: rgba(255, 255, 255, 0.15);\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(-20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes slideIn {\n            from {\n                opacity: 0;\n                transform: scale(0.9);\n            }\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n\n        @media (max-width: 768px) {\n            .dashboard-grid {\n                grid-template-columns: 1fr;\n            }\n\n            .greeting {\n                font-size: 1.8rem;\n            }\n\n            .clock {\n                font-size: 2.5rem;\n            }\n        }\n\n        .empty-state {\n            text-align: center;\n            color: #666;\n            padding: 40px 20px;\n            font-size: 0.95rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <div class=\"greeting\">\n                Olá, <span id=\"userName\">User</span>! 👋\n                <button class=\"name-edit\" onclick=\"openNameModal()\">Editar nome</button>\n            </div>\n            <div class=\"date-display\" id=\"dateDisplay\"></div>\n        </div>\n\n        <div class=\"dashboard-grid\">\n            <!-- Clock Card -->\n            <div class=\"card\">\n                <div class=\"card-title\">⏰ Relógio</div>\n                <div class=\"clock\" id=\"clock\">00:00:00</div>\n            </div>\n\n            <!-- Tasks Card -->\n            <div class=\"card\">\n                <div class=\"card-title\">✓ Tarefas</div>\n                <div class=\"tasks-container\" id=\"tasksContainer\"></div>\n                <div class=\"task-input-group\">\n                    <input\n                        type=\"text\"\n                        class=\"task-input\"\n                        id=\"taskInput\"\n                        placeholder=\"Nova tarefa...\"\n                        onkeypress=\"handleTaskKeyPress(event)\"\n                    >\n                    <button class=\"task-btn\" onclick=\"addTask()\">+</button>\n                </div>\n            </div>\n\n            <!-- Notes Card -->\n            <div class=\"card\">\n                <div class=\"card-title\">📝 Notas Rápidas</div>\n                <div class=\"notes-container\">\n                    <textarea\n                        class=\"note-textarea\"\n                        id=\"noteTextarea\"\n                        placeholder=\"Escreva suas notas aqui...\"\n                    ></textarea>\n                    <button class=\"note-save-btn\" onclick=\"saveNote()\">Salvar Nota</button>\n                    <div class=\"save-indicator\" id=\"saveIndicator\"></div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- Modal for Name Edit -->\n    <div class=\"modal\" id=\"nameModal\">\n        <div class=\"modal-content\">\n            <div class=\"modal-title\">Editar Nome</div>\n            <input\n                type=\"text\"\n                class=\"modal-input\"\n                id=\"nameInput\"\n                placeholder=\"Seu nome\"\n                onkeypress=\"handleNameKeyPress(event)\"\n            >\n            <div class=\"modal-buttons\">\n                <button class=\"modal-btn modal-btn-cancel\" onclick=\"closeNameModal()\">Cancelar</button>\n                <button class=\"modal-btn modal-btn-save\" onclick=\"saveName()\">Salvar</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Initialize\n        document.addEventListener('DOMContentLoaded', () => {\n            loadUserName();\n            updateDate();\n            updateClock();\n            loadTasks();\n            loadNote();\n\n            setInterval(updateClock, 1000);\n            setInterval(updateDate, 60000);\n        });\n\n        // User Name Management\n        function loadUserName() {\n            const savedName = localStorage.getItem('userName');\n            const name = savedName || 'User';\n            document.getElementById('userName').textContent = name;\n        }\n\n        function openNameModal() {\n            const currentName = document.getElementById('userName').textContent;\n            document.getElementById('nameInput').value = currentName;\n            document.getElementById('nameModal').classList.add('active');\n            document.getElementById('nameInput').focus();\n        }\n\n        function closeNameModal() {\n            document.getElementById('nameModal').classList.remove('active');\n        }\n\n        function saveName() {\n            const newName = document.getElementById('nameInput').value.trim();\n            if (newName) {\n                localStorage.setItem('userName', newName);\n                document.getElementById('userName').textContent = newName;\n                closeNameModal();\n            }\n        }\n\n        function handleNameKeyPress(e) {\n            if (e.key === 'Enter') saveName();\n            if (e.key === 'Escape') closeNameModal();\n        }\n\n        // Date and Clock\n        function updateDate() {\n            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };\n            const today = new Date().toLocaleDateString('pt-BR', options);\n            document.getElementById('dateDisplay').textContent = today;\n        }\n\n        function updateClock() {\n            const now = new Date();\n            const hours = String(now.getHours()).padStart(2, '0');\n            const minutes = String(now.getMinutes()).padStart(2, '0');\n            const seconds = String(now.getSeconds()).padStart(2, '0');\n            document.getElementById('clock').textContent = `${hours}:${minutes}:${seconds}`;\n        }\n\n        // Task Management\n        function loadTasks() {\n            const tasks = JSON.parse(localStorage.getItem('tasks')) || [];\n            const container = document.getElementById('tasksContainer');\n            container.innerHTML = '';\n\n            if (tasks.length === 0) {\n                container.innerHTML = '<div class=\"empty-state\">Nenhuma tarefa ainda. Adicione uma! 🎯</div>';\n                return;\n            }\n\n            tasks.forEach((task, index) => {\n                const taskEl = document.createElement('div');\n                taskEl.className = `task-item ${task.completed ? 'completed' : ''}`;\n                taskEl.innerHTML = `\n                    <input\n                        type=\"checkbox\"\n                        class=\"task-checkbox\"\n                        ${task.completed ? 'checked' : ''}\n                        onchange=\"toggleTask(${index})\"\n                    >\n                    <span class=\"task-text\">${escapeHtml(task.text)}</span>\n                    <button class=\"task-delete\" onclick=\"deleteTask(${index})\">×</button>\n                `;\n                container.appendChild(taskEl);\n            });\n        }\n\n        function addTask() {\n            const input = document.getElementById('taskInput');\n            const text = input.value.trim();\n\n            if (text) {\n                const tasks = JSON.parse(localStorage.getItem('tasks')) || [];\n                tasks.push({ text, completed: false });\n                localStorage.setItem('tasks', JSON.stringify(tasks));\n                input.value = '';\n                loadTasks();\n                input.focus();\n            }\n        }\n\n        function toggleTask(index) {\n            const tasks = JSON.parse(localStorage.getItem('tasks')) || [];\n            tasks[index].completed = !tasks[index].completed;\n            localStorage.setItem('tasks', JSON.stringify(tasks));\n            loadTasks();\n        }\n\n        function deleteTask(index) {\n            const tasks = JSON.parse(localStorage.getItem('tasks')) || [];\n            tasks.splice(index, 1);\n            localStorage.setItem('tasks', JSON.stringify(tasks));\n            loadTasks();\n        }\n\n        function handleTaskKeyPress(e) {\n            if (e.key === 'Enter') addTask();\n        }\n\n        // Note Management\n        function loadNote() {\n            const savedNote = localStorage.getItem('quickNote');\n            if (savedNote) {\n                document.getElementById('noteTextarea').value = savedNote;\n            }\n        }\n\n        function saveNote() {\n            const text = document.getElementById('noteTextarea').value;\n            localStorage.setItem('quickNote', text);\n\n            const indicator = document.getElementById('saveIndicator');\n            indicator.textContent = '✓ Salvo com sucesso!';\n            setTimeout(() => {\n                indicator.textContent = '';\n            }, 2000);\n        }\n\n        // Utility\n        function escapeHtml(text) {\n            const div = document.createElement('div');\n            div.textContent = text;\n            return div.innerHTML;\n        }\n    </script>\n</body>\n</html>","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"adc277e7-bd24-41fc-a811-f2f577697cb2"}
