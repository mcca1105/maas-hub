{
  "model": "haiku",
  "language": "portuguese",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline-script.js",
    "padding": 2
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/track-agent.sh"
          }
        ]
      }
    ]
  }
}
